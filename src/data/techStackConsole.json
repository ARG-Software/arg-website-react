{
  "ariaLabel": "ARG technology stack shell",
  "path": "arg@stack ~ /stack.sh",
  "meta": "interactive stack browser",
  "prompt": "arg@stack:~$",
  "inputPlaceholder": "type /help to check the commands",
  "commands": {
    "/languages": {
      "description": "shows production languages we use daily",
      "lines": ["TypeScript", "C# / .NET", "Node", "Python"]
    },
    "/databases": {
      "description": "shows storage, cache, and streaming tools",
      "lines": ["Postgres", "Redis", "Kafka", "ClickHouse", "MongoDB"]
    },
    "/frontend": {
      "description": "shows web and real-time UI tools",
      "lines": ["React", "Next.js", "TanStack Query", "GSAP"]
    },
    "/infra": {
      "description": "shows ship, run, and rollback tooling",
      "lines": ["Docker", "Kubernetes", "Terraform", "GitHub Actions", "AWS"]
    },
    "/observe": {
      "description": "shows observability tooling",
      "lines": ["OpenTelemetry", "Grafana", "Sentry", "Prometheus"]
    },
    "/principles": {
      "description": "shows the operating principles behind the stack",
      "lines": ["architecture-first", "no patchwork", "gold standard", "handoff-ready"]
    }
  },
  "systemCommands": {
    "/help": "lists available commands",
    "/clear": "clears the shell output"
  }
}
