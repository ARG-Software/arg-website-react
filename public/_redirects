# GA4 proxy — serves gtag.js and collection endpoint from own domain

/g/js https://www.googletagmanager.com/gtag/js 200
/g/collect https://www.google-analytics.com/g/collect 200

# LLM metadata aliases

/llm.txt /llms.txt 301
/full-llm.txt /llms-full.txt 301
/full-llms.txt /llms-full.txt 301

# Trailing-slash canonicalization — fixes Ahrefs "3XX in sitemap" errors
/partners         /partners/             301
/careers          /careers/              301
/about-us         /about-us/             301
/working-with-us  /working-with-us/      301
/contact          /contact/              301
/privacy          /privacy/              301
/terms            /terms/                301
/projects         /projects/             301
/blog             /blog/                 301
/projects/*       /projects/:splat/      301
/blog/*           /blog/:splat/          301

# Legacy URL redirects (prevents 404 from old article paths)

/articles/*    /blog/:splat    301
/clients/*     /partners/:splat   301
/team          /partners          301
/team/*        /partners/:splat   301

# Everything else → 404 page with correct HTTP status

/* /404.html 404
